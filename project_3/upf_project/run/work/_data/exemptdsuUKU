	// MSPA Function to convert int to simstate 
	function UPF::power_state_simstate mspa_int_to_simstate( int x );  
	UPF::power_state_simstate simState;
	if( x === 0 )
		simState = UPF::CORRUPT;
	else if( x === 1 )
		simState = UPF::CORRUPT_ON_ACTIVITY;
	else if( x === 2 )
		simState = UPF::CORRUPT_ON_CHANGE;
	else if( x === 3 )
		simState = UPF::CORRUPT_STATE_ON_ACTIVITY;
	else if( x === 4 )
		simState = UPF::CORRUPT_STATE_ON_CHANGE;
	else if( x === 5 )
		simState = UPF::NORMAL;
	return simState;
	endfunction: mspa_int_to_simstate  
	// MSPA Function to convert simstate to int 
	function int mspa_simstate_to_int( UPF::power_state_simstate simState );  
	int x;
	if( simState === UPF::CORRUPT )
		x = 0;
	else if( simState === UPF::CORRUPT_ON_ACTIVITY )
		x = 1;
	else if( simState === UPF::CORRUPT_ON_CHANGE)
		x = 2;
	else if( simState === UPF::CORRUPT_STATE_ON_ACTIVITY)
		x = 3;
	else if( simState === UPF::CORRUPT_STATE_ON_CHANGE)
		x = 4;
	else if( simState === UPF::NORMAL)
		x = 5;
	return x;
	endfunction: mspa_simstate_to_int
/*Function for msg str for iepcoa/idpcoa*/
function string msg_str_func(UPF::power_state_simstate simState,int isIepCoa);
if(simState == UPF::CORRUPT)
	msg_str_func = isIepCoa ? "power is switched OFF" : "power shut OFF";
else if(simState == UPF::CORRUPT_ON_ACTIVITY)
	msg_str_func = isIepCoa ? "driving supply is in CORRUPT_ON_ACTIVITY simstate": "driving supply CORRUPT_ON_ACTIVITY simstate";
else if(simState == UPF::CORRUPT_STATE_ON_ACTIVITY)
	msg_str_func = isIepCoa ? "driving supply is in CORRUPT_STATE_ON_ACTIVITY simstate": "driving supply CORRUPT_STATE_ON_ACTIVITY simstate";
else if(simState == UPF::CORRUPT_STATE_ON_CHANGE)
	msg_str_func = isIepCoa ? "driving supply is in CORRUPT_STATE_ON_CHANGE simstate": "driving supply CORRUPT_STATE_ON_CHANGE simstate";
else if(simState == UPF::CORRUPT_ON_CHANGE)
	msg_str_func = isIepCoa ? "driving supply is in CORRUPT_ON_CHANGE simstate": "driving supply CORRUPT_ON_CHANGE simstate";
endfunction

function int msg_str_func_int(UPF::power_state_simstate simState,int isIepCoa);
if(simState == UPF::CORRUPT)
	msg_str_func_int = isIepCoa ? 1 : 2;
else if(simState == UPF::CORRUPT_ON_ACTIVITY)
	msg_str_func_int = isIepCoa ? 3 : 4;
else if(simState == UPF::CORRUPT_STATE_ON_ACTIVITY)
	msg_str_func_int = isIepCoa ? 5 : 6;
else if(simState == UPF::CORRUPT_STATE_ON_CHANGE)
	msg_str_func_int = isIepCoa ? 7 : 8;
else if(simState == UPF::CORRUPT_ON_CHANGE)
	msg_str_func_int = isIepCoa ? 9 : 10;
endfunction

