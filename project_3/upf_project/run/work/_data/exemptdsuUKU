function bit is_same_root_supply_driver (input UPF::supply_net_type net1, input UPF::supply_net_type net2);       
    if (net1.voltage == net2.voltage)                                      
        return 1'b1;                                                       
    else                                                                   
        return 1'b0;                                                       
endfunction                                                                
                                                                           
