    return net.state;                                                      
endfunction                                                                
function UPF::supply_net_type MSPA_PARALLEL_UPF1 (input UPF::supply_net_type bus[]   
         ,input string res_net_name = "", input string net_name[] = {});             
                                                                           
    automatic int count = 1;                                               
    automatic int voltage = 0;                                             
    UPF::supply_net_type on_net;                                           
    automatic UPF::state state;                                            
    automatic int error = 0;                                               
    automatic string str;                                                  
                                                                           
    state = bus[0].state;                                                  
                                                                           
    foreach(bus[i]) begin                                                  
        case (bus[i].state)                                                
            UPF::UNDETERMINED:                                                  
               begin                                                       
                   state = UPF::UNDETERMINED;                                   
               end                                                         
            UPF::PARTIAL_ON:                                                    
               begin                                                       
                   state = (state == UPF::UNDETERMINED) ? UPF::UNDETERMINED : UPF::PARTIAL_ON;   
               end                                                         
            UPF::FULL_ON:                                                       
               begin                                                       
                   state = (state == UPF::UNDETERMINED) ? UPF::UNDETERMINED : ((state == UPF::FULL_ON) ? UPF::FULL_ON : UPF::PARTIAL_ON )  ;      
               end                                                         
            UPF::OFF:                                                           
               begin                                                       
                   state = (state == UPF::UNDETERMINED) ? UPF::UNDETERMINED : ((state == UPF::OFF) ? UPF::OFF : UPF::PARTIAL_ON )  ;      
               end                                                         
            default : ;                                                    
         endcase                                                           
                                                                           
        if ( bus[i].state != UPF::OFF && bus[i].state != UPF::UNDETERMINED) begin    
            if (count) begin                                               
                voltage = bus[i].voltage;                                  
                on_net = bus[i];                                           
                count = 0;                                                 
            end                                                            
            else if (!is_same_root_supply_driver(on_net,bus[i])) begin     
                error = 1;                                                 
                break;                                                     
            end                                                            
        end                                                                
    end                                                                    
                                                                           
    if (error) begin                                                       
        MSPA_PARALLEL_UPF1 = '{UPF::UNDETERMINED,0};                            
        $swrite (str, "Different voltages driven by active drivers of parallel supply net %s\nDrivers are:-", res_net_name);
        foreach (bus[i]) begin                                             
            $swrite ( str, "%s\n",str);                                
            $swrite ( str, "%s %s: {%p uV, %s}",str, net_name[i],    
                           bus[i].voltage, get_net_state(bus[i]));         
        end                                                                
        $pa_messagelog( "%:S (vsim-%:I) %:C: Time: %s, %s ",        
                   $pa_get_svrt("Error","8927","--"), "8927", "MSPA_RSLV_PARALLEL", $pa_pptime, str );
    end                                                                    
    else                                                                   
        MSPA_PARALLEL_UPF1 = '{state,voltage};                             
                                                                           
endfunction                                                                

                                                                         
function UPF::supply_net_type MSPA_ONE_HOT_UPF1 (input UPF::supply_net_type bus[]    
                ,input string res_net_name = "", input string net_name[] = {}); 
                                                                           
    automatic int count = 0;                                               
    automatic int undeter_state = 0;                                       
    automatic int idx = 0;                                                 
    automatic string str;                                                  
                                                                           
    foreach(bus[i]) begin                                
     if ( UPF::get_supply_on_state(bus[i]) ) begin                              
          count++;                                                         
          idx = i;                                                         
     end                                                                   
     if ( (bus[i].state) == UPF::UNDETERMINED ) begin                           
          undeter_state = 1;                                               
     end                                                                   
    end                                                                    
                                                                           
    if (undeter_state == 1)                                                
        MSPA_ONE_HOT_UPF1 = '{UPF::UNDETERMINED,0};                             
    else if (count == 0)                                                   
        MSPA_ONE_HOT_UPF1 = '{UPF::OFF,0};                                      
    else if (count == 1)                                                   
        MSPA_ONE_HOT_UPF1 = bus[idx];                                      
    else begin                                                             
        MSPA_ONE_HOT_UPF1 = '{UPF::UNDETERMINED,0};                             
        $swrite (str,"More than one driver is ON for one_hot supply net: %s\nDrivers are:-", res_net_name);
        foreach (bus[i]) begin                                  
            $swrite ( str, "%s\n",str);                                
            $swrite ( str, "%s %s: {%p uV, %s}",str, net_name[i],    
                          bus[i].voltage, get_net_state(bus[i]));  
        end                                                                
        $pa_messagelog( "%:S (vsim-%:I) %:C: Time: %s, %s ",        
                   $pa_get_svrt("Error","8928","--"), "8928", "MSPA_RSLV_ONE_HOT", $pa_pptime, str ); 
    end                                                                    
endfunction                                                                

                                                                         
function UPF::supply_net_type MSPA_STRONG_UPF1 (input UPF::supply_net_type bus[]);   
                                                                           
    automatic int voltage = 0;                                             
    automatic UPF::state state;                                            
                                                                           
    state = bus[0].state;                                                  
                                                                           
    foreach (bus[i]) begin                                                 
        case (bus[i].state)                                                
            UPF::UNDETERMINED:                                                  
               begin                                                       
                   state = UPF::UNDETERMINED;                                   
                   voltage = 0;                                            
                   break;                                                  
               end                                                         
            UPF::PARTIAL_ON:                                                    
               begin                                                       
                   if(state != UPF::FULL_ON) begin                              
                        state = UPF::PARTIAL_ON;                                
                   end                                                     
                   voltage = (voltage > bus[i].voltage) ? voltage : bus[i].voltage;
               end                                                         
            UPF::FULL_ON:                                                       
               begin                                                       
                   state = UPF::FULL_ON ;                                       
                   voltage = (voltage > bus[i].voltage) ? voltage : bus[i].voltage;
               end                                                         
            UPF::OFF: ;                                                         
            default : ;                                                    
         endcase                                                           
    end                                                                    
    MSPA_STRONG_UPF1 = '{state,voltage};                                   
endfunction                                                                

                                                                         
function UPF::supply_net_type MSPA_WEAK_UPF1 (input UPF::supply_net_type bus[]);     
                                                                           
    automatic int voltage = 0;                                             
    automatic UPF::state state;                                            
                                                                           
    state = bus[0].state;                                                  
    voltage = bus[0].voltage;                                              
                                                                           
    foreach (bus[i]) begin                                                 
        case (bus[i].state)                                                
            UPF::UNDETERMINED:                                                  
               begin                                                       
                   if(state == UPF::OFF || state == UPF::UNDETERMINED) begin         
                        voltage = 0;                                       
                        state = UPF::UNDETERMINED;                              
                   end                                                     
               end                                                         
            UPF::PARTIAL_ON:                                                    
               begin                                                       
                   if(state == UPF::FULL_ON || state == UPF::PARTIAL_ON) begin       
                        voltage = (voltage < bus[i].voltage) ? voltage : bus[i].voltage;
                   end                                                     
                   else begin                                              
                        voltage = bus[i].voltage;                          
                   end                                                     
                   if(state != UPF::FULL_ON) begin                              
                        state = UPF::PARTIAL_ON;                                
                   end                                                     
               end                                                         
            UPF::FULL_ON:                                                       
               begin                                                       
                   if(state == UPF::FULL_ON || state == UPF::PARTIAL_ON) begin       
                        voltage = (voltage < bus[i].voltage) ? voltage : bus[i].voltage;
                   end                                                     
                   else begin                                              
                        voltage = bus[i].voltage;                          
                   end                                                     
                   state = UPF::FULL_ON ;                                       
               end                                                         
            UPF::OFF: ;                                                         
            default : ;                                                    
         endcase                                                           
    end                                                                    
    MSPA_WEAK_UPF1 = '{state,voltage};                                     
endfunction                                                                

                                                                         
function UPF::supply_net_type MSPA_EITHER_UPF1 (input UPF::supply_net_type bus[]);   
                                                                           
    automatic int voltage = 0;                                             
    automatic UPF::state state;                                            
                                                                           
    state = bus[0].state;                                                  
    voltage = bus[0].voltage;                                              
                                                                           
    foreach (bus[i]) begin                                                 
        case (bus[i].state)                                                
            UPF::UNDETERMINED:                                                  
               begin                                                       
                   voltage = 0;                                            
                   state = UPF::UNDETERMINED;                                   
                   break;                                                  
               end                                                         
            UPF::PARTIAL_ON:                                                    
               begin                                                       
                   if(state == UPF::OFF) begin                                  
                        voltage = bus[i].voltage;                          
                   end                                                     
                   else begin                                              
                        voltage = (voltage < bus[i].voltage) ? voltage : bus[i].voltage;
                   end                                                     
                   if(state != UPF::FULL_ON) begin                              
                        state = UPF::PARTIAL_ON;                                
                   end                                                     
               end                                                         
            UPF::FULL_ON:                                                       
               begin                                                       
                   if(state == UPF::OFF) begin                                  
                        voltage = bus[i].voltage;                          
                   end                                                     
                   else begin                                              
                        voltage = (voltage < bus[i].voltage) ? voltage : bus[i].voltage;
                   end                                                     
                   state = UPF::FULL_ON ;                                       
               end                                                         
            UPF::OFF: ;                                                         
            default : ;                                                    
         endcase                                                           
    end                                                                    
    MSPA_EITHER_UPF1 = '{state,voltage};                                   
endfunction                                                                

                                                                         
function bit are_states_equal (input UPF::supply_net_type net1, input UPF::supply_net_type net2, input apply_partial_on_translation);  
    automatic UPF::state state1 = net1.state;                              
    automatic UPF::state state2 = net2.state;                              
    if (apply_partial_on_translation)                                      
    begin                                                                  
        if (state1 == UPF::PARTIAL_ON)                                          
        begin                                                              
            if  ($pa_partial_on_trans)                                     
                state1 = UPF::FULL_ON;                                          
            else                                                           
                state1 = UPF::OFF;                                              
        end                                                                
        if (state2 == UPF::PARTIAL_ON)                                          
        begin                                                              
            if  ($pa_partial_on_trans)                                     
                state2 = UPF::FULL_ON;                                          
            else                                                           
                state2 = UPF::OFF;                                              
        end                                                                
    end                                                                    
    if (state1 == state2)                                                  
        return 1'b1;                                                       
    else                                                                   
        return 1'b0;                                                       
endfunction                                                                
 function bit MSPA_PARALLEL_UPF1_CHECK (input UPF::supply_net_type bus[],       
                                        input int width, input partial_on_tran);  
     automatic int warning = 0;                                        
    for (int i = 0 ; i < width-1; i ++) begin                          
        if(bus[i].state == UPF::UNDETERMINED)                           
        begin                                                          
            warning = 1;                                               
            break;                                                     
        end                                                            
        if (!are_states_equal(bus[i],bus[i+1],partial_on_tran))
        begin                                                          
            warning = 1;                                               
            break;                                                     
        end                                                            
    end                                                                
    if(bus[width -1].state == UPF::UNDETERMINED)                        
    begin                                                              
        warning = 1;                                                   
    end                                                                
    if (warning)                                                       
        MSPA_PARALLEL_UPF1_CHECK = 1'b1;                               
    else                                                               
       MSPA_PARALLEL_UPF1_CHECK = 1'b0;                                
 endfunction                                                           
