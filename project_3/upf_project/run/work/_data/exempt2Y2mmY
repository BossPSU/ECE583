`mspa_module

`define PA_NO_EVENT                 8'b0_0000_000
`define PA_STORE_VALUE              8'b0_0000_001
`define PA_STORE_X                  8'b0_0000_00x

`define PA_RESTORE_VALUE            8'b0_0000_010
`define PA_CORRUPT_REGISTER         8'b0_0000_100
`define PA_RELEASE_REGISTER         8'b0_0001_000
`define PA_SET_REGISTER             8'b0_0010_000
`define PA_RESET_REGISTER           8'b0_0100_000
`define PA_RESTORE_HOLD_REGISTER    8'b0_1000_000


`define PA_TIME0_EVENT 8'b1_0000_000
`define PA_MASK 8'b0_1111_110
`define PA_STORE_MASK 8'b0_0000_001

/*Balloon latch configuration for level sensitive dual controls */

module bl_level_model_testO (
  SAVE, SC, RESTORE, RC, RTC, PWR, RETPWR, BIAS_TRIGGER, RET_SUP_COR, SAV_RES_COR, 
  PA_EVENT
  );


  input SAVE;
  input SC;
  input RESTORE;
  input RC;
  input RTC;
  input PWR;
  input RETPWR;
  input BIAS_TRIGGER;
  input RET_SUP_COR;
  input SAV_RES_COR;
  output [7:0] PA_EVENT;
  reg [7:0] PA_EVENT;
  
  wire RETPWR_RES = RET_SUP_COR ? RETPWR : 1'b1;

  reg restore_event = 1'b0;
  reg save_event = 1'b0;
  reg save_edge = 1'b0;
  reg save_end = 1'b0;
  reg resave = 1'b0;
  integer time_stamp = 0;
  reg time_zero_trigger = 1'b0;

  reg time0_ret_event_mask = 1'b0;

  (*UPF_PA_OBJ = "TRUE"*) always @(posedge time_zero_trigger) begin
    time0_ret_event_mask = 1'b1;
    if(RETPWR_RES === 1'bx || RETPWR_RES === 1'b0) begin
        PA_EVENT = `PA_CORRUPT_REGISTER | `PA_TIME0_EVENT;
    end else if (SAV_RES_COR && RESTORE === 1'b1 && SAVE === 1'b1 && SC === 1'b1 && RC === 1'b1) begin
        PA_EVENT = `PA_CORRUPT_REGISTER | `PA_TIME0_EVENT;
    end
  end


  initial begin
    PA_EVENT = `PA_NO_EVENT;
    time_zero_trigger = 1'b1;
  end


 /* Not making SC or RC part of sensitivity list because they should be evaluated when there is an activity on save/restore sig */
  always @(PWR or RETPWR or RESTORE or negedge RTC or posedge SAVE) begin: restore_process

  if (time0_ret_event_mask) begin 
      if (!RETPWR_RES) begin
          PA_EVENT = `PA_CORRUPT_REGISTER | `PA_STORE_X;
      end else if (!RETPWR && RESTORE) begin
          PA_EVENT = `PA_CORRUPT_REGISTER | `PA_STORE_X;
      end else if (SAV_RES_COR && SAVE && RESTORE && SC && RC) begin
          PA_EVENT = `PA_CORRUPT_REGISTER | `PA_STORE_X;
      end else if (!RETPWR) begin
          PA_EVENT = `PA_STORE_X;
      end else if (!PWR && !RTC) begin
          PA_EVENT = `PA_STORE_X;
      end else if (!PWR) begin
          PA_EVENT = `PA_NO_EVENT;
      end else if (RESTORE) begin
          PA_EVENT = (PA_EVENT & `PA_STORE_VALUE) | `PA_RESTORE_HOLD_REGISTER;
          /*if PA_EVENT[0] is not 'x' then preserve it otherwise make it 0*/;
          /*because by masking with PA_STORE_VALUE we are removing store_x bit;*/
      if (PA_EVENT[0] === 1'bx) PA_EVENT[0] = 1'b0; 
      end else begin
          if(PA_EVENT & `PA_MASK)
             PA_EVENT = `PA_RELEASE_REGISTER;
      end
  end

  end:restore_process

  always @(posedge PWR) begin
     if (RESTORE && PWR && RETPWR_RES) begin
         time_stamp = $time;
     end
  end
 
  always @(posedge RC) begin
     if (RESTORE && PWR && RETPWR_RES) begin
     if (time_stamp == $time)
          PA_EVENT = (PA_EVENT & `PA_STORE_MASK) | `PA_RESTORE_HOLD_REGISTER;
     end
  end
  // To capture Proper Restore Event for Coverage purpose : if PA_RESTORE_HOLD_REGISTER @ negedge of RS => proper restore 
  /* negedge SAVE because of level sensitive behavior. Cant make this process sensitive to q hence 
  need to take special care and trigger the store_value at trailing edge of level sensitive signal as defined in lrm. */
  always @(negedge SAVE) begin:save_process
  if (time0_ret_event_mask) begin 
      if (RETPWR && PWR) begin
          if (SC) begin 
              if (PA_EVENT & `PA_STORE_MASK & `PA_STORE_VALUE) begin 
                  PA_EVENT = (PA_EVENT & `PA_MASK) | `PA_NO_EVENT;
                  resave = 1'b1;
              end else begin
                  PA_EVENT = (PA_EVENT & `PA_MASK) | `PA_STORE_VALUE;
              end
              /* To capture Proper Save Event for Coverage purpose */
              save_edge = 1'b1;
          end
      end else begin
          PA_EVENT = (PA_EVENT & `PA_MASK) | `PA_STORE_X;
      end 
  end 
  end:save_process

  always @(posedge resave) begin
      PA_EVENT = (PA_EVENT & `PA_MASK) | `PA_STORE_VALUE;
      resave = 1'b0; 
  end
  always @(posedge save_edge) begin
      save_end = 1'b1; 
  end
  always @(posedge save_end) begin
      PA_EVENT = (PA_EVENT & `PA_MASK);
      save_end = 1'b0; 
      save_edge = 1'b0; 
  end
  always @(negedge PA_EVENT[6]) begin
     if (time0_ret_event_mask) begin 
         if (PWR && RETPWR_RES) begin
             restore_event <= 1'b1;
         end
     end
  end 

  always @(negedge SAVE) begin
  if (time0_ret_event_mask) begin 
      if (RETPWR && PWR & SC) begin
              save_event <= 1'b1;
      end 
  end 
  end

  always @(posedge save_event) begin
      save_event <= 1'b0; 
  end
  always @(posedge restore_event) begin
      restore_event <= 1'b0; 
  end

endmodule

 
