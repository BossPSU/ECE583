/* First level pa_event handler */ 
module PA_EVENT_MODIFIER (MS_CONFIG, SET, RESET, CLK, SC, RC, RTC, PA_EVENT_IN, PA_EVENT_OUT);
  input [7:0] PA_EVENT_IN;
  input MS_CONFIG, SET, RESET, CLK, SC, RC, RTC;
  output reg [7:0] PA_EVENT_OUT;

  bit prcs_src_signal;
  always @(PA_EVENT_IN or posedge prcs_src_signal or negedge SC or negedge RC or negedge RTC) begin
      if ( prcs_src_signal )  begin
          PA_EVENT_OUT = `PA_CORRUPT_REGISTER | `PA_STORE_X;
      end else if ((PA_EVENT_IN & `PA_RELEASE_REGISTER)
                     || (MS_CONFIG && !RTC && (PA_EVENT_IN & `PA_RESTORE_HOLD_REGISTER)))  begin
          if (RESET)  begin
              PA_EVENT_OUT = (PA_EVENT_IN & `PA_STORE_MASK) | `PA_RELEASE_REGISTER | `PA_RESET_REGISTER;
          end else if (SET)  begin
              PA_EVENT_OUT = (PA_EVENT_IN & `PA_STORE_MASK) | `PA_RELEASE_REGISTER | `PA_SET_REGISTER;
          end else if (MS_CONFIG && !RTC && (PA_EVENT_IN & `PA_RESTORE_HOLD_REGISTER))  begin
              //false restore hold in novopt flow
              PA_EVENT_OUT = (PA_EVENT_IN & `PA_STORE_MASK) | `PA_RELEASE_REGISTER;
          end else begin
              PA_EVENT_OUT = PA_EVENT_IN;
          end
      end else if (((PA_EVENT_IN & (`PA_CORRUPT_REGISTER)) != `PA_NO_EVENT)  && !RTC)  begin
              PA_EVENT_OUT = (PA_EVENT_IN & `PA_MASK) | `PA_STORE_X ;
      end else begin
              PA_EVENT_OUT = PA_EVENT_IN;
      end

      if (MS_CONFIG && (PA_EVENT_IN & `PA_STORE_VALUE) && !RTC) begin
              PA_EVENT_OUT = (PA_EVENT_IN & `PA_MASK) | `PA_STORE_X ;
      end

      if (!RC) begin
              PA_EVENT_OUT &= (~(`PA_RESTORE_VALUE) & ~(`PA_RESTORE_HOLD_REGISTER));
      end
      if (!SC) begin
              PA_EVENT_OUT &= ~(`PA_STORE_VALUE);
      end
  end
endmodule
/* vsim readable pa_event generator */ 
module PA_EVENT_PROCESSOR (PWR_FROM_BIAS, PA_EVENT, PWR_DOMAIN);

  input [7:0] PA_EVENT;
  input PWR_FROM_BIAS;
  input PWR_DOMAIN;
  event pa_store_value;
  event pa_store_x;
  event pa_restore_value;
  event pa_corrupt_register;
  event pa_release_register;
  event pa_restore_hold_register;
  event pa_set_register;
  event pa_reset_register;

  always @(PA_EVENT[0]) begin
    if ((PA_EVENT & `PA_STORE_X) === `PA_STORE_X) begin
        -> pa_store_x;
    end
    if (PA_EVENT & `PA_STORE_VALUE) begin
        -> pa_store_value;
    end
  end

  always @(PA_EVENT[6:1]) begin
    if (PA_EVENT & `PA_RESTORE_VALUE) begin
        -> pa_restore_value;
    end
    if (PA_EVENT & `PA_CORRUPT_REGISTER) begin
        -> pa_corrupt_register;
        //triggered only at time 0 once
        if (PA_EVENT & `PA_TIME0_EVENT) #0 -> pa_corrupt_register;
    end
    if (PA_EVENT & `PA_RESTORE_HOLD_REGISTER) begin
        -> pa_restore_hold_register;
    end
    if (PA_EVENT & `PA_RELEASE_REGISTER) begin
        if (PA_EVENT & `PA_RESET_REGISTER) begin
            -> pa_release_register;
            #0 -> pa_reset_register;
        end else if (PA_EVENT & `PA_SET_REGISTER) begin
            -> pa_release_register;
            #0 -> pa_set_register;
        end else begin
            -> pa_release_register;
        end
    end
  end

  /* PWR can also toggle from bias action, taking care of this here in novopt flow */
  always @(negedge PWR_FROM_BIAS) begin
    if (PA_EVENT & `PA_CORRUPT_REGISTER) begin
        -> pa_corrupt_register;
    end
  end
  always @(negedge PWR_DOMAIN) begin
    -> pa_corrupt_register;
  end
  always @(posedge PWR_DOMAIN) begin
    if (!(PA_EVENT[6:1])) begin
        -> pa_release_register;
    end
  end
endmodule
