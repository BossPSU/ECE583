module mspa_iso_chk_cell_multi #(parameter chkid = 0, level = 0) (
input isolation_input, 
output isolation_output,
input [level:0]clamp_value,
input [level:0]clamp_latch,power,isolation_signal,
input bit_type,sink_pwr,
input int portid,pdid,
input [4:0] cctrl);

int i;
reg [level:0]iso_level_out;
always@(power,isolation_signal,isolation_input)
begin : pcs
	for(i=level; i >= 0; i=i-1) begin
		if(power[i])
		begin
			if(isolation_signal[i] === 1'bx)
				iso_level_out[i] = bit_type ? 'b0 : 'bx;
			else if(isolation_signal[i] === 1'b1) begin
				if(clamp_latch[i] != 1)
					iso_level_out[i] = clamp_value[i];
			end else
				iso_level_out[i] = (i === level) ? isolation_input : iso_level_out[i+1];
		end
		else
			iso_level_out[i] = bit_type ? 'b0 : 'bx;
	end
end

assign isolation_output = iso_level_out[0];

endmodule
