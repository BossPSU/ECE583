module mspa_iso_chk_cell #(parameter chkid = 0) (
input isolation_input, 
output reg isolation_output,
input clamp_value,
input bit_type,clamp_latch,power,isolation_signal,
input sink_pwr,
input int portid,pdid,
input [4:0] cctrl);

always@(power,isolation_signal,isolation_input)
begin : pcs
		if(power)
		begin
			if(isolation_signal === 1'bx)
				isolation_output = bit_type ? 'b0 : 'bx;
			else if(isolation_signal === 1'b1) begin
				if(clamp_latch !== 1)
					isolation_output = clamp_value;
			end else
				isolation_output = isolation_input;
		end
		else
			isolation_output = bit_type ? 'b0 : 'bx;
	end

endmodule
